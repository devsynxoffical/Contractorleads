generator client {
  provider      = "prisma-client-js"
  // Include Linux engines so Prisma works on cPanel after generate
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-3.0.x", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  phone               String?
  emailVerifiedAt     DateTime?
  role                String   @default("USER")
  plan                String   @default("starter")
  subscriptionStatus  String   @default("trialing")
  stripeCustomerId    String?  @unique
  stripeSubscriptionId String? @unique
  stripePriceId       String?
  isActive            Boolean  @default(true)
  adminNotes          String?
  creditsRemaining    Float    @default(13.3)
  onboardingComplete  Boolean  @default(false)
  /// Post-purchase product walkthrough dismissed or finished
  productTourCompleted Boolean @default(false)
  darkMode            Boolean  @default(false)
  companyName         String?
  /// Agency owner contact (managed from admin + settings)
  ownerName           String?
  ownerEmail          String?
  ownerPhone          String?
  businessDescription String?
  services            String?
  idealCustomer       String?
  serviceAreas        String?
  mainGoal            String?
  crmWebhookUrl       String?
  crmWebhookSecret   String?
  crmWebhookEnabled   Boolean  @default(false)
  slackWebhookUrl     String?
  slackEnabled        Boolean  @default(false)
  ghlWebhookUrl       String?
  ghlEnabled          Boolean  @default(false)
  /// Admin kill-switches (default on — plan still gates availability)
  ssoEnabled          Boolean  @default(true)
  apiEnabled          Boolean  @default(true)
  mcpEnabled          Boolean  @default(true)
  apiMonthlyLimit     Int?
  apiMonthlyUsed      Int      @default(0)
  apiUsageResetAt     DateTime?
  apiKeyHash          String?
  apiKeyLast4         String?
  /// Product / scrape notification emails (CAN-SPAM opt-in)
  emailMarketingOptIn Boolean  @default(true)
  /// Unique shareable referral / affiliate code
  referralCode        String?  @unique
  /// Withdrawable referral commission balance (USD)
  referralBalanceUsd  Float    @default(0)
  /// Who referred this user (agency signup attribution)
  referredByUserId    String?
  referredBy          User?    @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referralsMade       User[]   @relation("UserReferrals")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  searches        Search[]
  savedLeads      SavedLead[]
  scripts         Script[]
  creditLedger    CreditLedger[]
  activities      ActivityLog[]
  exports         Export[]
  aiConversations AiConversation[]
  smtpSettings    UserSmtpSettings?
  smtpAccounts    SmtpAccount[]
  leadEmails      LeadEmail[]
  emailSequence   EmailSequence?
  emailEnrollments EmailEnrollment[]
  passwordResets  PasswordResetToken[]
  referralsAsReferrer Referral[] @relation("ReferrerReferrals")
  referralAsReferred  Referral?  @relation("ReferredReferral")
  referralWithdrawals ReferralWithdrawal[]
  referralEarnings    ReferralEarningLedger[]
  teamMembers     TeamMember[]
  leadUnlocks     LeadUnlock[]
}

/// Agency+ seat invites managed by the account owner.
model TeamMember {
  id          String    @id @default(cuid())
  ownerUserId String
  owner       User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  role        String    @default("member") // admin | member | viewer
  status      String    @default("pending") // pending | active | revoked
  invitedAt   DateTime  @default(now())
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([ownerUserId, email])
  @@index([ownerUserId, status])
}

/// Persisted AI assistant threads (home / Ask Expert).
model AiConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String      @default("New chat")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AiMessage[]

  @@index([userId, updatedAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant
  content        String
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

model Lead {
  id                        String   @id @default(cuid())
  businessName              String
  ownerName                 String?
  ownerTitle                String?
  ownerSourceUrl            String?
  ownerConfidence           Int?
  teamMembersJson           String?
  peopleEnrichedAt          DateTime?
  phone                     String?
  email                     String?
  emailSourceUrl            String?
  website                   String?
  googleRating              Float?
  reviewCount               Int?
  address                   String?
  googleMapsLink            String?
  yearsInBusiness           Int?
  leadScore                 Int      @default(0)
  serviceCategory           String?
  revenueRangeEstimate      String?
  websiteQualityScore       Int?
  marketingOpportunityScore Int?
  ppcOpportunityScore       Int?
  seoOpportunityScore       Int?
  outreachAngle             String?
  facebook                  String?
  instagram                 String?
  yelpUrl                   String?
  yelpRating                Float?
  yelpReviews               Int?
  tiktok                    String?
  nextdoor                  String?
  houzzUrl                  String?
  houzzRating               Float?
  houzzReviews              Int?
  linkedinUrl               String?
  linkedinCompanyUrl        String?
  linkedinOwnerUrl          String?
  linkedinConfidenceScore   Float?
  linkedinOwnerConfidenceScore Float?
  linkedinType              String   @default("none")
  youtube                   String?
  facebookAdsData           String?
  facebookAdsCheckedAt      DateTime?
  socialEnrichedAt          DateTime?
  verificationStatus        String   @default("verified")
  industry                  String?
  country                   String   @default("US")
  state                     String?
  city                      String?
  zip                       String?
  latitude                  Float?
  longitude                 Float?
  qualityTier               String?
  searchId                  String?
  search                    Search?  @relation(fields: [searchId], references: [id], onDelete: SetNull)
  createdAt                 DateTime @default(now())

  savedBy SavedLead[]
  emails  LeadEmail[]
  unlocks LeadUnlock[]

  @@index([industry])
  @@index([country])
  @@index([googleMapsLink])
  @@index([createdAt])
}

/// Paid unlock — contact/export fields stay redacted until this exists.
model LeadUnlock {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  credits   Float    @default(1.33)
  createdAt DateTime @default(now())

  @@unique([userId, leadId])
  @@index([userId, createdAt])
}

model Search {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry    String
  country     String   @default("US")
  locationScope String @default("local")
  state       String?
  city        String?
  zip         String?
  radius      Int?
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())

  leads Lead[]
}

model SavedLead {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId    String
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status    String     @default("new")
  favorite  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  notes     LeadNote[]
  emailEnrollments EmailEnrollment[]
  emails    LeadEmail[]

  @@unique([userId, leadId])
}

model LeadNote {
  id          String    @id @default(cuid())
  savedLeadId String
  savedLead   SavedLead @relation(fields: [savedLeadId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime  @default(now())
}

model Script {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  title         String?
  content       String
  relatedLeadId String?
  createdAt     DateTime @default(now())
}

model CreditLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  action    String
  reference String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  metadata  String?
  createdAt DateTime @default(now())
}

model Export {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  format    String
  leadIds   String
  createdAt DateTime @default(now())
}

/// Editable permission templates for MANAGER and SUB_ADMIN staff roles.
model AdminRoleTemplate {
  id          String   @id @default(cuid())
  role        String   @unique // MANAGER | SUB_ADMIN
  label       String
  permissions String // JSON string array of permission keys
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Pending agency signups awaiting business-email verification.
model EmailVerification {
  id           String   @id @default(cuid())
  email        String
  phone        String
  name         String?
  /// Optional referral code captured at signup start
  referralCode String?
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
}

/// Admin-editable monthly list prices used for billing display + referral commission.
model PlanPricingConfig {
  id         String   @id @default("default")
  /// JSON: { "trial": 0, "starter": 19.99, "growth": 49, "agency": 99, "enterprise": 0 }
  pricesJson String   @default("{\"trial\":0,\"starter\":19.99,\"growth\":49,\"agency\":99,\"enterprise\":0}")
  updatedAt  DateTime @updatedAt
}

/// Admin-editable Stripe Billing keys (overrides env when set).
model StripeBillingConfig {
  id             String   @id @default("default")
  secretKey      String   @default("")
  webhookSecret  String   @default("")
  priceStarter   String   @default("")
  priceGrowth    String   @default("")
  priceAgency    String   @default("")
  updatedAt      DateTime @updatedAt
}

/// One signup attributed to a referrer. Commission pays on first paid plan purchase.
model Referral {
  id                String    @id @default(cuid())
  referrerId        String
  referrer          User      @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId    String    @unique
  referredUser      User      @relation("ReferredReferral", fields: [referredUserId], references: [id], onDelete: Cascade)
  status            String    @default("pending") // pending | rewarded | blocked
  /// Legacy credit fields (unused — kept for existing rows)
  rewardCredits     Float     @default(0)
  milestoneBonus    Float     @default(0)
  commissionUsd     Float     @default(0)
  milestoneBonusUsd Float     @default(0)
  planAtReward      String?
  purchaseAmountUsd Float?
  createdAt         DateTime  @default(now())
  rewardedAt        DateTime?

  @@index([referrerId, createdAt])
  @@index([status])
}

/// Singleton admin config for referral cash commissions and milestone tiers.
model ReferralRewardConfig {
  id                 String   @id @default("default")
  enabled            Boolean  @default(true)
  /// Percent of first paid plan monthly price paid as commission
  commissionPercent  Float    @default(20)
  minWithdrawalUsd   Float    @default(25)
  /// Legacy — unused
  creditsPerReferral Float    @default(0)
  /// JSON: [{ "minReferrals": 10, "bonusUsd": 25 }, ...]
  milestonesJson     String   @default("[{\"minReferrals\":10,\"bonusUsd\":25},{\"minReferrals\":50,\"bonusUsd\":100},{\"minReferrals\":100,\"bonusUsd\":250}]")
  updatedAt          DateTime @updatedAt
}

/// User-requested cash payout from referralBalanceUsd.
model ReferralWithdrawal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountUsd     Float
  method        String    @default("paypal") // paypal | bank | other
  payoutDetails String
  status        String    @default("pending") // pending | paid | rejected
  adminNote     String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

/// Append-only cash ledger for referral earnings and withdrawals.
model ReferralEarningLedger {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountUsd  Float
  action     String // commission | milestone | withdrawal | withdrawal_reversal
  reference  String?
  metaJson   String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

/// One-time password reset links (forgot password flow).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Admin-editable branded email templates (verify, welcome, reset, scrape).
model EmailTemplate {
  id                 String   @id @default(cuid())
  key                String   @unique // verify | welcome | reset | scrape
  label              String
  enabled            Boolean  @default(true)
  subject            String
  preheader          String
  heroTitle          String
  heroSubtitle       String
  headline           String
  body               String
  ctaLabel           String
  ctaPath            String
  feature1Title      String?
  feature1Body       String?
  feature2Title      String?
  feature2Body       String?
  feature3Title      String?
  feature3Body       String?
  secondaryTitle     String?
  secondaryBody      String?
  secondaryCtaLabel  String?
  secondaryCtaPath   String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

/// Per-agency SMTP so outreach sends from their own mailbox.
/// @deprecated Prefer SmtpAccount (multiple mailboxes). Kept for migration.
model UserSmtpSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  host         String
  port         Int      @default(587)
  secure       Boolean  @default(false)
  username     String
  /// AES-encrypted SMTP password
  passwordEnc  String
  fromEmail    String
  fromName     String?
  enabled      Boolean  @default(true)
  lastTestedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Multiple SMTP / from-addresses per agency (Gmail, Outlook, team inboxes).
model SmtpAccount {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String      @default("Primary")
  host         String
  port         Int         @default(587)
  secure       Boolean     @default(false)
  username     String
  passwordEnc  String
  fromEmail    String
  fromName     String?
  enabled      Boolean     @default(true)
  isDefault    Boolean     @default(false)
  lastTestedAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  emails       LeadEmail[]

  @@index([userId, isDefault])
  @@index([userId, enabled])
}

/// Outbound and inbound emails tied to a lead (send from detail + reply webhook).
model LeadEmail {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  savedLeadId   String?
  savedLead     SavedLead?   @relation(fields: [savedLeadId], references: [id], onDelete: SetNull)
  smtpAccountId String?
  smtpAccount   SmtpAccount? @relation(fields: [smtpAccountId], references: [id], onDelete: SetNull)
  /// outbound | inbound
  direction     String
  fromEmail     String
  toEmail       String
  subject       String
  body          String
  /// sent | failed | received
  status        String
  error         String?
  messageId     String?
  inReplyTo     String?
  enrollmentId  String?
  /// Set when an agent opens an inbound message in the inbox
  readAt        DateTime?
  createdAt     DateTime     @default(now())

  @@index([userId, leadId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, direction, createdAt])
  @@index([fromEmail])
  @@index([toEmail])
}

/// Day 1 / 2 / 3 email automation templates for scraped/saved leads.
model EmailSequence {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @default("Lead nurture")
  enabled     Boolean  @default(true)
  day1Subject String   @default("Quick intro")
  day1Body    String   @default("Hi {{ownerName}},\n\nI noticed {{businessName}} and thought we could help with more booked jobs.\n\nWorth a quick chat?\n\n{{fromName}}")
  day2Subject String   @default("Following up")
  day2Body    String   @default("Hi {{ownerName}},\n\nJust bumping this in case you missed it — happy to share how agencies like yours are filling their calendar.\n\n{{fromName}}")
  day3Subject String   @default("Last note from me")
  day3Body    String   @default("Hi {{ownerName}},\n\nI'll close the loop here. If timing is better later, just reply and I'll send details.\n\n{{fromName}}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  enrollments EmailEnrollment[]
}

/// Tracks Day 1/2/3 sends for a saved lead.
model EmailEnrollment {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sequenceId  String
  sequence    EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  savedLeadId String
  savedLead   SavedLead     @relation(fields: [savedLeadId], references: [id], onDelete: Cascade)
  status      String        @default("active") // active | completed | paused | failed
  day1SentAt  DateTime?
  day2SentAt  DateTime?
  day3SentAt  DateTime?
  lastError   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, savedLeadId])
  @@index([status, createdAt])
}

/// Anonymous marketing site visitors (cookie `cl_mkt_vid`) for outreach lists.
model MarketingVisitor {
  id              String    @id @default(cuid())
  visitorKey      String    @unique
  email           String?
  emailOptIn      Boolean   @default(false)
  source          String?
  landingPath     String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  referrer        String?
  userAgent       String?
  visitCount      Int       @default(1)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  convertedUserId String?
  convertedAt     DateTime?

  @@index([email])
  @@index([emailOptIn, lastSeenAt])
  @@index([convertedUserId])
}
