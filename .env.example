# Database — local Docker Postgres (docker compose up -d)
# Or Railway Postgres URL in production
DATABASE_URL="postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# AI Provider
OPENAI_API_KEY=""

# Lead Data Sources (required for live lead generation)
GOOGLE_PLACES_API_KEY=""
YELP_FUSION_API_KEY=""

# Optional enrichment
# Public web search fallback for verified Nextdoor/Houzz profiles (serper.dev)
SERPER_API_KEY=""
HOUZZ_SEARCH_ENDPOINT=""
HOUZZ_API_KEY=""
NEXTDOOR_SEARCH_ENDPOINT=""
NEXTDOOR_API_KEY=""
LINKEDIN_DATA_API_KEY=""

# Meta / Facebook Ads Library & page search
META_APP_ID=""
META_APP_SECRET=""
# Optional: user access token with ads_read (overrides app token)
META_ACCESS_TOKEN=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
