# Database — local Docker Postgres (docker compose up -d)
# Or Railway Postgres URL in production
DATABASE_URL="postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# AI Provider
OPENAI_API_KEY=""

# Lead Data Sources (required for live lead generation)
GOOGLE_PLACES_API_KEY=""
YELP_FUSION_API_KEY=""

# Optional enrichment
# Public web search fallback for verified Nextdoor/Houzz profiles (serper.dev)
SERPER_API_KEY=""
HOUZZ_SEARCH_ENDPOINT=""
HOUZZ_API_KEY=""
NEXTDOOR_SEARCH_ENDPOINT=""
NEXTDOOR_API_KEY=""
LINKEDIN_DATA_API_KEY=""

# Meta / Facebook Ads Library & page search
META_APP_ID=""
META_APP_SECRET=""
# Optional: long-lived user access token with ads_archive / Ads Library access
META_ACCESS_TOKEN=""

# Transactional email (signup verification) — set one of:
RESEND_API_KEY=""
# RESEND_FROM="Contractor Leads <onboarding@yourdomain.com>"
SENDGRID_API_KEY=""
# EMAIL_FROM="Contractor Leads <noreply@yourdomain.com>"

# App URL (required for verification email links in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Railway checklist (product APIs — no MCP server):
# DATABASE_URL, JWT_SECRET, NEXT_PUBLIC_APP_URL,
# GOOGLE_PLACES_API_KEY (Places + Autocomplete enabled + billing),
# YELP_FUSION_API_KEY, OPENAI_API_KEY,
# META_ACCESS_TOKEN (long-lived), LINKEDIN_DATA_API_KEY (Proxycurl),
# RESEND_API_KEY or SENDGRID_API_KEY
