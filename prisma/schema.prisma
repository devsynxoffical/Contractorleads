generator client {
  provider      = "prisma-client-js"
  // Include Linux engines so Prisma works on cPanel after generate
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-3.0.x", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  phone               String?
  emailVerifiedAt     DateTime?
  role                String   @default("USER")
  plan                String   @default("trial")
  subscriptionStatus  String   @default("trialing")
  isActive            Boolean  @default(true)
  adminNotes          String?
  creditsRemaining    Float    @default(20)
  onboardingComplete  Boolean  @default(false)
  darkMode            Boolean  @default(false)
  companyName         String?
  /// Agency owner contact (managed from admin + settings)
  ownerName           String?
  ownerEmail          String?
  ownerPhone          String?
  businessDescription String?
  services            String?
  idealCustomer       String?
  serviceAreas        String?
  mainGoal            String?
  crmWebhookUrl       String?
  crmWebhookSecret   String?
  crmWebhookEnabled   Boolean  @default(false)
  slackWebhookUrl     String?
  slackEnabled        Boolean  @default(false)
  ghlWebhookUrl       String?
  ghlEnabled          Boolean  @default(false)
  /// Admin kill-switches (default on — plan still gates availability)
  ssoEnabled          Boolean  @default(true)
  apiEnabled          Boolean  @default(true)
  mcpEnabled          Boolean  @default(true)
  apiMonthlyLimit     Int?
  apiMonthlyUsed      Int      @default(0)
  apiUsageResetAt     DateTime?
  apiKeyHash          String?
  apiKeyLast4         String?
  /// Product / scrape notification emails (CAN-SPAM opt-in)
  emailMarketingOptIn Boolean  @default(true)
  /// Unique shareable referral / affiliate code
  referralCode        String?  @unique
  /// Who referred this user (agency signup attribution)
  referredByUserId    String?
  referredBy          User?    @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referralsMade       User[]   @relation("UserReferrals")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  searches        Search[]
  savedLeads      SavedLead[]
  scripts         Script[]
  creditLedger    CreditLedger[]
  activities      ActivityLog[]
  exports         Export[]
  aiConversations AiConversation[]
  smtpSettings    UserSmtpSettings?
  emailSequence   EmailSequence?
  emailEnrollments EmailEnrollment[]
  passwordResets  PasswordResetToken[]
  referralsAsReferrer Referral[] @relation("ReferrerReferrals")
  referralAsReferred  Referral?  @relation("ReferredReferral")
}

/// Persisted AI assistant threads (home / Ask Expert).
model AiConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String      @default("New chat")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AiMessage[]

  @@index([userId, updatedAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant
  content        String
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

model Lead {
  id                        String   @id @default(cuid())
  businessName              String
  ownerName                 String?
  ownerTitle                String?
  ownerSourceUrl            String?
  ownerConfidence           Int?
  teamMembersJson           String?
  peopleEnrichedAt          DateTime?
  phone                     String?
  email                     String?
  emailSourceUrl            String?
  website                   String?
  googleRating              Float?
  reviewCount               Int?
  address                   String?
  googleMapsLink            String?
  yearsInBusiness           Int?
  leadScore                 Int      @default(0)
  serviceCategory           String?
  revenueRangeEstimate      String?
  websiteQualityScore       Int?
  marketingOpportunityScore Int?
  ppcOpportunityScore       Int?
  seoOpportunityScore       Int?
  outreachAngle             String?
  facebook                  String?
  instagram                 String?
  yelpUrl                   String?
  yelpRating                Float?
  yelpReviews               Int?
  tiktok                    String?
  nextdoor                  String?
  houzzUrl                  String?
  houzzRating               Float?
  houzzReviews              Int?
  linkedinUrl               String?
  linkedinCompanyUrl        String?
  linkedinOwnerUrl          String?
  linkedinConfidenceScore   Float?
  linkedinOwnerConfidenceScore Float?
  linkedinType              String   @default("none")
  youtube                   String?
  facebookAdsData           String?
  facebookAdsCheckedAt      DateTime?
  socialEnrichedAt          DateTime?
  verificationStatus        String   @default("verified")
  industry                  String?
  country                   String   @default("US")
  state                     String?
  city                      String?
  zip                       String?
  latitude                  Float?
  longitude                 Float?
  qualityTier               String?
  searchId                  String?
  search                    Search?  @relation(fields: [searchId], references: [id], onDelete: SetNull)
  createdAt                 DateTime @default(now())

  savedBy SavedLead[]

  @@index([industry])
  @@index([country])
  @@index([googleMapsLink])
  @@index([createdAt])
}

model Search {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  industry    String
  country     String   @default("US")
  locationScope String @default("local")
  state       String?
  city        String?
  zip         String?
  radius      Int?
  resultCount Int      @default(0)
  createdAt   DateTime @default(now())

  leads Lead[]
}

model SavedLead {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId    String
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status    String     @default("new")
  favorite  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  notes     LeadNote[]
  emailEnrollments EmailEnrollment[]

  @@unique([userId, leadId])
}

model LeadNote {
  id          String    @id @default(cuid())
  savedLeadId String
  savedLead   SavedLead @relation(fields: [savedLeadId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime  @default(now())
}

model Script {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  title         String?
  content       String
  relatedLeadId String?
  createdAt     DateTime @default(now())
}

model CreditLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  action    String
  reference String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  metadata  String?
  createdAt DateTime @default(now())
}

model Export {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  format    String
  leadIds   String
  createdAt DateTime @default(now())
}

/// Editable permission templates for MANAGER and SUB_ADMIN staff roles.
model AdminRoleTemplate {
  id          String   @id @default(cuid())
  role        String   @unique // MANAGER | SUB_ADMIN
  label       String
  permissions String // JSON string array of permission keys
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Pending agency signups awaiting business-email verification.
model EmailVerification {
  id           String   @id @default(cuid())
  email        String
  phone        String
  name         String?
  /// Optional referral code captured at signup start
  referralCode String?
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
}

/// One successful signup attributed to a referrer (affiliate).
model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String    @unique
  referredUser   User      @relation("ReferredReferral", fields: [referredUserId], references: [id], onDelete: Cascade)
  status         String    @default("pending") // pending | rewarded | blocked
  rewardCredits  Float     @default(0)
  milestoneBonus Float     @default(0)
  createdAt      DateTime  @default(now())
  rewardedAt     DateTime?

  @@index([referrerId, createdAt])
  @@index([status])
}

/// Singleton-ish admin config for referral rewards and milestone tiers.
model ReferralRewardConfig {
  id                 String   @id @default("default")
  enabled            Boolean  @default(true)
  creditsPerReferral Float    @default(10)
  /// JSON: [{ "minReferrals": 10, "bonusCredits": 50 }, ...]
  milestonesJson     String   @default("[{\"minReferrals\":10,\"bonusCredits\":50},{\"minReferrals\":50,\"bonusCredits\":200},{\"minReferrals\":100,\"bonusCredits\":500}]")
  updatedAt          DateTime @updatedAt
}

/// One-time password reset links (forgot password flow).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Admin-editable branded email templates (verify, welcome, reset, scrape).
model EmailTemplate {
  id                 String   @id @default(cuid())
  key                String   @unique // verify | welcome | reset | scrape
  label              String
  enabled            Boolean  @default(true)
  subject            String
  preheader          String
  heroTitle          String
  heroSubtitle       String
  headline           String
  body               String
  ctaLabel           String
  ctaPath            String
  feature1Title      String?
  feature1Body       String?
  feature2Title      String?
  feature2Body       String?
  feature3Title      String?
  feature3Body       String?
  secondaryTitle     String?
  secondaryBody      String?
  secondaryCtaLabel  String?
  secondaryCtaPath   String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

/// Per-agency SMTP so outreach sends from their own mailbox.
model UserSmtpSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  host         String
  port         Int      @default(587)
  secure       Boolean  @default(false)
  username     String
  /// AES-encrypted SMTP password
  passwordEnc  String
  fromEmail    String
  fromName     String?
  enabled      Boolean  @default(true)
  lastTestedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Day 1 / 2 / 3 email automation templates for scraped/saved leads.
model EmailSequence {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @default("Lead nurture")
  enabled     Boolean  @default(true)
  day1Subject String   @default("Quick intro")
  day1Body    String   @default("Hi {{ownerName}},\n\nI noticed {{businessName}} and thought we could help with more booked jobs.\n\nWorth a quick chat?\n\n{{fromName}}")
  day2Subject String   @default("Following up")
  day2Body    String   @default("Hi {{ownerName}},\n\nJust bumping this in case you missed it — happy to share how agencies like yours are filling their calendar.\n\n{{fromName}}")
  day3Subject String   @default("Last note from me")
  day3Body    String   @default("Hi {{ownerName}},\n\nI'll close the loop here. If timing is better later, just reply and I'll send details.\n\n{{fromName}}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  enrollments EmailEnrollment[]
}

/// Tracks Day 1/2/3 sends for a saved lead.
model EmailEnrollment {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sequenceId  String
  sequence    EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  savedLeadId String
  savedLead   SavedLead     @relation(fields: [savedLeadId], references: [id], onDelete: Cascade)
  status      String        @default("active") // active | completed | paused | failed
  day1SentAt  DateTime?
  day2SentAt  DateTime?
  day3SentAt  DateTime?
  lastError   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, savedLeadId])
  @@index([status, createdAt])
}

/// Anonymous marketing site visitors (cookie `cl_mkt_vid`) for outreach lists.
model MarketingVisitor {
  id              String    @id @default(cuid())
  visitorKey      String    @unique
  email           String?
  emailOptIn      Boolean   @default(false)
  source          String?
  landingPath     String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  referrer        String?
  userAgent       String?
  visitCount      Int       @default(1)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  convertedUserId String?
  convertedAt     DateTime?

  @@index([email])
  @@index([emailOptIn, lastSeenAt])
  @@index([convertedUserId])
}
